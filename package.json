{
  "name": "zekr",
  "version": "2.1.0",
  "description": "A simple test framework for ReScript",
  "main": "./src/Zekr.js",
  "module": "./src/Zekr.js",
  "bin": {
    "zekr": "./bin/zekr.mjs"
  },
  "files": [
    "src/**/*.res",
    "src/**/*.js",
    "bin/zekr.mjs",
    "bin/zekr-run.mjs",
    "bin/resolve-runner.mjs",
    "rescript.json"
  ],
  "scripts": {
    "build": "rescript",
    "clean": "rescript clean",
    "watch": "rescript -w",
    "test": "rescript && node bin/zekr.mjs",
    "precoverage": "rescript && node scripts/generate-sourcemaps.mjs src",
    "coverage": "c8 node bin/zekr.mjs",
    "semantic-release": "semantic-release"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brnrdog/zekr.git"
  },
  "bugs": {
    "url": "https://github.com/brnrdog/zekr/issues"
  },
  "homepage": "https://github.com/brnrdog/zekr#readme",
  "keywords": [
    "rescript",
    "test",
    "testing",
    "framework"
  ],
  "author": "Bernardo Gurgel <brnrdog@hey.com>",
  "license": "MIT",
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.0",
    "c8": "^11.0.0",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "rescript": "^12.1.0",
    "semantic-release": "^25.0.3",
    "source-map": "^0.7.6"
  },
  "c8": {
    "include": [
      "src/**/*.js"
    ],
    "exclude": [
      "src/**/*.js.map",
      "src/Types.js"
    ],
    "reporter": [
      "text",
      "html"
    ],
    "report-dir": "coverage",
    "all": true
  },
  "dependencies": {
    "jsdom": "^28.1.0"
  }
}
